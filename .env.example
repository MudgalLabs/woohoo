########################################
# Woohoo's Environment Configuration
########################################

# Database configuration.
# Change the user and password to something secure.
WOOHOO_DB_USER=postgres
WOOHOO_DB_PASSWORD=postgres
WOOHOO_DB_NAME=woohoo

# Local dev (host-side) — used by `npm run dev` against a compose-exposed db
# DATABASE_URL="postgres://postgres:postgres@localhost:42071/woohoo"
# In-compose (container-side) — web reaches db over woohoo_network
DATABASE_URL="postgres://postgres:postgres@woohoo_db:5432/woohoo"

# Auth
BETTER_AUTH_SECRET=

BETTER_AUTH_URL=http://localhost:3000

ENABLE_EMAIL_PASSWORD_AUTH=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# Extension — URLs baked into the extension at build time.
# VITE_DEV_API_URL is used by `npm run dev` in ext/ (point it at wherever
# your local web app runs). VITE_PROD_API_URL is used by `npm run build`
# in ext/ (self-hosters: set this to your deployed web app's domain).
VITE_DEV_API_URL=http://localhost:3000
VITE_PROD_API_URL=


# Bodhveda — in-app notifications (inbox bell, welcome notification on signup).
# Create a project at https://console.bodhveda.com and generate two API keys:
#   1. A "full" scope key for the server (sending notifications, creating recipients).
#   2. A "recipient" scope key for the browser bundle (safe to expose; only lets
#      the caller act as a single recipient).
BODHVEDA_API_KEY=
NEXT_PUBLIC_BODHVEDA_RECIPIENT_KEY=
# Optional — defaults to https://api.bodhveda.com. Set only to point at a
# locally-running Bodhveda instance.
BODHVEDA_API_URL=
NEXT_PUBLIC_BODHVEDA_API_URL=


# Resend — transactional email (follow-up digest for Pro users).
# https://resend.com/api-keys. Requires woohoo.to to be added as a verified
# sending domain (DKIM CNAMEs + SPF + DMARC in DNS).
RESEND_API_KEY=
RESEND_FROM_EMAIL="Woohoo <hey@your.domain>"


# Cron service — kill switch for the daily digest worker. Set to "false" to
# let the container run but skip every tick (useful if deliverability issues
# surface post-launch and we need to pause without redeploying).
CRON_ENABLED=true
