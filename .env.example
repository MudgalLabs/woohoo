########################################
# Woohoo's Environment Configuration
########################################

# Database configuration.
# Change the user and password to something secure.
WOOHOO_DB_USER=postgres
WOOHOO_DB_PASSWORD=postgres
WOOHOO_DB_NAME=woohoo

# Local dev (host-side) — used by `npm run dev` against a compose-exposed db
# DATABASE_URL="postgres://postgres:postgres@localhost:42071/woohoo"
# In-compose (container-side) — web reaches db over woohoo_network
DATABASE_URL="postgres://postgres:postgres@woohoo_db:5432/woohoo"

# Auth
BETTER_AUTH_SECRET=

BETTER_AUTH_URL=http://localhost:3000

ENABLE_EMAIL_PASSWORD_AUTH=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# Extension — URLs baked into the extension at build time.
# VITE_DEV_API_URL is used by `npm run dev` in ext/ (point it at wherever
# your local web app runs). VITE_PROD_API_URL is used by `npm run build`
# in ext/ (self-hosters: set this to your deployed web app's domain).
VITE_DEV_API_URL=http://localhost:3000
VITE_PROD_API_URL=
