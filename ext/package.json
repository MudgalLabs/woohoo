{
    "name": "@woohoo/ext",
    "type": "module",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "npm run build:chrome && npm run build:firefox",
        "build:chrome": "tsc -b && BROWSER=chrome NODE_ENV=production vite build --mode production",
        "build:firefox": "tsc -b && BROWSER=firefox NODE_ENV=production vite build --mode production",
        "preview": "vite preview"
    },
    "dependencies": {
        "@woohoo/api": "*",
        "lucide-react": "^1.8.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@crxjs/vite-plugin": "^2.4.0",
        "@types/chrome": "^0.1.37",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "typescript": "~5.9.3",
        "vite": "^8.0.0",
        "vite-plugin-zip-pack": "^1.2.4"
    }
}
