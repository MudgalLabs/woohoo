{
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["ES2020"],
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "isolatedModules": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
