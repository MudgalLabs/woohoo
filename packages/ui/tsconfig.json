{
    "compilerOptions": {
        "target": "ES2017",
        "lib": ["dom", "dom.iterable", "esnext"],
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "isolatedModules": true,
        "jsx": "react-jsx",
        "paths": {
            "@woohoo/ui": ["./src/index.ts"],
            "@woohoo/ui/components": ["./src/components"],
            "@woohoo/ui/components/*": ["./src/components/*"],
            "@woohoo/ui/lib/utils": ["./src/lib/utils.ts"],
            "@woohoo/ui/lib": ["./src/lib"]
        }
    },
    "include": ["src/**/*.ts", "src/**/*.tsx"],
    "exclude": ["node_modules"]
}
